  issn = {1936-4490},
  doi = {10.1002/cjas.1419},
  urldate = {2026-05-06},
  abstract = {This paper offers a review of published conceptual and empirical studies indexed in the main academic search databases, covering literature on the internationalization of small and medium-sized firms. We analyzed a total of 554 papers covering the period between 1977 and 2014, and found the following general trends: empirical research focuses mainly on Europe and is characterized by a diversity that identifies 74 different topics. This study provides academics and practitioners with a clear perspective on future directions of SME internationalization and contributes to our understanding of the relevant research to date. Copyright \copyright{} 2016 ASAC. Published by John Wiley \& Sons, Ltd.},
  copyright = {Copyright \copyright{} 2016 ASAC. Published by John Wiley \& Sons, Ltd.},
  langid = {french},
  keywords = {Internationalisation,internationalization,internationalization topics,literature review,petite entreprise,PME,revue de la litterature,small firms,SME,sujets sur l'internationalisation},
  file = {..\\..\\..\\..\\..\\..\\Zotero\\storage\\GAUCSY2T\\Ribau et al. - 2018 - SME internationalization research Mapping the state of the art.pdf;..\\..\\..\\..\\..\\..\\Zotero\\storage\\KMD7473B\\cjas.html}
}

